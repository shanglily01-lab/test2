[Unit]
Description=Crypto Analyzer - 币本位主策略 (coin_futures_trader_service.py)
After=network-online.target mysql.service crypto-app-main.service
Wants=network-online.target
Requires=crypto-app-main.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/crypto-analyzer
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/crypto-analyzer/venv/bin/python coin_futures_trader_service.py
Restart=on-failure
RestartSec=15
StandardOutput=append:/opt/crypto-analyzer/logs/coin_futures_systemd.log
StandardError=append:/opt/crypto-analyzer/logs/coin_futures_systemd.log

MemoryMax=1G
TasksMax=512

[Install]
WantedBy=multi-user.target
